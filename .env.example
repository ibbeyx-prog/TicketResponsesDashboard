# Copy to ".env" and fill in values. Never commit ".env" with secrets.

#

# Required (bot + dashboard)

TELEGRAM_TOKEN=

SUPABASE_URL=

SUPABASE_KEY=



# --- Webhook on Railway (recommended) ---

# In Railway: enable a public domain on the bot service, then set the hostname

# only (no scheme, no path). The app registers ``https://<host>/webhook``.

# Railway sets PORT; uvicorn listens on it — do not point Telegram at Streamlit.

RAILWAY_PUBLIC_DOMAIN=



# Required whenever RAILWAY_PUBLIC_DOMAIN, WEBHOOK_BASE_URL, or WEBHOOK_FULL_URL

# is set. Telegram sends this on every webhook POST as

# X-Telegram-Bot-Api-Secret-Token so random clients cannot forge updates.

# Use only A–Z, a–z, 0–9, underscore, hyphen; 16–32 characters is plenty.

TELEGRAM_WEBHOOK_SECRET=



# Optional overrides (same URL rules as ``webhook_config.py``):

# Site origin only (no ``/webhook``); we append ``/webhook``. Trailing

# ``/webhook`` is stripped so you never get ``.../webhook/webhook``.

WEBHOOK_BASE_URL=

# Exact callback ``https://host/webhook`` (highest priority).

WEBHOOK_FULL_URL=



# --- Local / tunnel (e.g. ngrok) ---

# Tunnel the bot port (``PORT``, default 8000), not Streamlit (8501).

# You can set WEBHOOK_BASE_URL to ``https://your-subdomain.ngrok-free.app``

# or use WEBHOOK_FULL_URL for the exact callback.



# Optional — Command Center (Streamlit posts assignments into this chat)

# Bot token: TELEGRAM_TOKEN (required for bot too), or TELEGRAM_BOT_TOKEN / TG_BOT_TOKEN.

# Group id: TELEGRAM_GROUP_CHAT_ID, or TELEGRAM_GROUP_ID / TG_GROUP_ID. Use either:

#   - Numeric supergroup id (often negative), e.g. -1001234567890

#   - Public supergroup @username, e.g. @my_field_team

# You do NOT need to delete your webhook to obtain this; run /chatid in the group

# (as an allowed user if TELEGRAM_ALLOWED_USERNAMES is set) or use @username below.

TELEGRAM_GROUP_CHAT_ID=



# Optional — Telethon for Command Center (see bot_utils.py). When TG_API_ID and

# TG_API_HASH are set, dashboard posts use Telethon; otherwise only TELEGRAM_TOKEN

# + TELEGRAM_GROUP_CHAT_ID are used (HTTP Bot API).

TG_API_ID=

TG_API_HASH=

TG_BOT_TOKEN=

TG_GROUP_ID=



# Optional — override table name for the Command Center field-team directory.

FIELD_ENGINEERS_TABLE=dashboard_field_engineers



# Optional — bot

PORT=8000

LOG_LEVEL=INFO

# Optional — comma-separated Telegram @usernames (no @ prefix required) allowed

# to use /respond, /chatid, assignment flows, etc. /start and /help are always

# allowed in private so anyone can confirm the bot is online.

TELEGRAM_ALLOWED_USERNAMES=

BOT_SESSIONS_TABLE=bot_sessions

TICKETS_TABLE=tickets_active

ATTENDANCE_LOGS_TABLE=ticket_attendance_logs

TICKET_PHOTOS_BUCKET=ticket-photos



# When "true", after a successful group assignment the bot posts one short

# follow-up message duplicating the assignment line(s). Field staff must

# reply to THAT bot message (not the coordinator's) so Telegram privacy

# mode still delivers updates. Otherwise turn privacy OFF in @BotFather,

# or field replies in DM will not reach the bot from a plain group reply.

TELEGRAM_GROUP_REPLY_BRIDGE=



# When "true", the bot calls deleteWebhook on process shutdown. Default is

# off so stopping the dev server does not wipe Telegram's webhook URL.

TELEGRAM_DELETE_WEBHOOK_ON_SHUTDOWN=



# Optional — when "true", ``restore_webhook.py --delete`` passes

# drop_pending_updates=true to Telegram (clears the stuck update queue).

TELEGRAM_DELETE_WEBHOOK_DROP_PENDING=



# Required — dashboard auth

# Shared password for the Streamlit dashboard. Without this, the dashboard

# refuses to render (fails closed). On Streamlit Community Cloud, put this in

# *Manage app -> Settings -> Secrets* instead of in .env.

DASHBOARD_PASSWORD=

