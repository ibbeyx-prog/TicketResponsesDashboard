{
  "name": "Python 3.11 (TicketResponsesDashboard)",
  "image": "mcr.microsoft.com/devcontainers/python:1-3.11-bookworm",
  "customizations": {
    "codespaces": {
      "openFiles": [
        "bot.py",
        "app.py"
      ]
    },
    "vscode": {
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python"
      },
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance"
      ]
    }
  },
  "updateContentCommand": "pip3 install --user -r requirements.txt && echo 'Packages installed'",
  "portsAttributes": {
    "8000": {
      "label": "Bot (FastAPI webhook)",
      "onAutoForward": "notify"
    },
    "8501": {
      "label": "Dashboard (Streamlit)",
      "onAutoForward": "openPreview"
    }
  },
  "forwardPorts": [
    8000,
    8501
  ]
}
